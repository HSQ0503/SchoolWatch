generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model SchoolEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  date      String // "YYYY-MM-DD"
  name      String
  type      String // "no-school" | "early-dismissal" | "event" | "exam" | "deadline"
  endDate   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  email        String    @unique
  passwordHash String
  otpCode      String?
  otpExpiresAt DateTime?
  otpAttempts  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Announcement {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  body      String
  type      String // "info" | "warning" | "urgent"
  pinned    Boolean  @default(false)
  active    Boolean  @default(true)
  expiresAt String? // "YYYY-MM-DD" or null
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrepTalk {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  youtubeUrl  String
  weekDate    String // "YYYY-MM-DD"
  description String?
  likes       Int      @default(0)
  dislikes    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LunchMenu {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  weekStart String   @unique // "YYYY-MM-DD" (Sunday of the week)
  days      Json     // Raw Flik API days array
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
